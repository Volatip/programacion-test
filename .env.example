# Example env file for local development.
# Copy to .env.local and keep real secrets ONLY there.

APP_ENV=development
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database resolution order:
# 1) DATABASE_URL when explicitly provided.
# 2) POSTGRES_* variables below (recommended for local Docker).
# 3) sqlite:///./sql_app.db fallback only for local/dev flows.
DATABASE_URL=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=programacion
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-your-local-postgres-password

# FastAPI docs stay hidden in production unless explicitly enabled.
EXPOSE_API_DOCS=false

# Empty local PostgreSQL bootstraps can create a first admin only in local/dev.
ENABLE_BOOTSTRAP_ADMIN=false
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_RUT=12345678-9
